<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Light palette. Mirrors Palette.Dark.xaml. Tweak any token here and the running
        app updates (XAML hot reload friendly).
    -->

    <!-- Surfaces -->
    <Color x:Key="BgColor">#F4F5F7</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceElevatedColor">#FAFBFD</Color>
    <Color x:Key="SurfaceHoverColor">#ECEEF2</Color>
    <Color x:Key="BorderColor">#DDE0E5</Color>
    <Color x:Key="BorderStrongColor">#B8BDC6</Color>

    <!-- Accent (Xbox green) -->
    <Color x:Key="AccentColor">#107C10</Color>
    <Color x:Key="AccentHoverColor">#0D650D</Color>
    <Color x:Key="AccentPressedColor">#085408</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#1A1D24</Color>
    <Color x:Key="TextSecondaryColor">#5A6170</Color>
    <Color x:Key="TextDisabledColor">#A0A6B0</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- Selection glow -->
    <Color x:Key="SelectionGlowColor">#3D107C10</Color>

</ResourceDictionary>
