<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Dark palette. Defines only color tokens. The brushes that consume them live in
        Tokens.xaml so we can swap palettes at runtime without touching the brushes.
    -->

    <!-- Surfaces -->
    <Color x:Key="BgColor">#0F1115</Color>
    <Color x:Key="SurfaceColor">#181B21</Color>
    <Color x:Key="SurfaceElevatedColor">#22262E</Color>
    <Color x:Key="SurfaceHoverColor">#2A2F38</Color>
    <Color x:Key="BorderColor">#2A2F38</Color>
    <Color x:Key="BorderStrongColor">#3A4150</Color>

    <!-- Accent (Xbox green) -->
    <Color x:Key="AccentColor">#107C10</Color>
    <Color x:Key="AccentHoverColor">#16A916</Color>
    <Color x:Key="AccentPressedColor">#0D650D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#F2F3F5</Color>
    <Color x:Key="TextSecondaryColor">#9AA0AB</Color>
    <Color x:Key="TextDisabledColor">#5A6170</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- Selection glow -->
    <Color x:Key="SelectionGlowColor">#3D107C10</Color>

</ResourceDictionary>
